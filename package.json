    "@solana/web3.js": "^1.95.0",
    "better-sqlite3": "^11.3.0",
    "bn.js": "^5.2.3",
    "bs58": "^6.0.0",
    "commander": "^12.1.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.4.5",
    "otpauth": "^9.5.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/bn.js": "^5.2.0",
